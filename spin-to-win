<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get Bristol Investing - Daily Spin Wheel</title>
    <style>
        :root {
            --purple: #7B2CBF;
            --light-bg: #F4F9F4;
            --dark-text: #222;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--light-bg);
            color: var(--dark-text);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            box-sizing: border-box;
        }

        .container {
            text-align: center;
            max-width: 500px;
            width: 100%;
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.05);
        }

        h1 {
            color: var(--purple);
            margin-bottom: 5px;
            font-size: 24px;
        }

        p.subtitle {
            color: #666;
            margin-bottom: 25px;
            font-size: 15px;
        }

        /* The Wheel Layout */
        .wheel-wrapper {
            position: relative;
            width: 320px;
            height: 320px;
            margin: 0 auto 30px auto;
        }

        /* The Ticker/Pointer arrow at the top */
        .pointer {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 15px solid transparent;
            border-right: 15px solid transparent;
            border-top: 25px solid var(--purple);
            z-index: 10;
        }

        canvas {
            display: block;
            border-radius: 50%;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            transition: transform 4s cubic-bezier(0.15, 0.85, 0.35, 1);
        }

        /* Controls & Results */
        .btn {
            background-color: var(--purple);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(123, 44, 191, 0.3);
            transition: all 0.2s ease;
        }

        .btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(123, 44, 191, 0.4);
        }

        .btn:disabled {
            background-color: #ccc;
            box-shadow: none;
            cursor: not-allowed;
        }

        .result-box {
            display: none;
            margin-top: 20px;
            padding: 15px;
            border: 2px dashed var(--purple);
            border-radius: 8px;
            background: #F9F5FF;
        }

        .code-display {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 1px;
            color: var(--purple);
            margin: 10px 0;
        }

        .lockout-message {
            display: none;
            color: #d90429;
            font-weight: 500;
            margin-top: 15px;
            background: #ffe3e3;
            padding: 12px;
            border-radius: 8px;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Get Bristol Investing</h1>
    <p class="subtitle">Spin the wheel to unlock an exclusive workshop discount voucher! (1 spin per day)</p>

    <div class="wheel-wrapper">
        <div class="pointer"></div>
        <canvas id="wheelCanvas" width="320" height="320"></canvas>
    </div>

    <button id="spinBtn" class="btn" onclick="spinWheel()">Spin the Wheel</button>

    <div id="lockoutMsg" class="lockout-message"></div>

    <div id="resultBox" class="result-box">
        <h3 style="margin: 0; color: #2b9348;">🎉 You won a <span id="rewardAmount"></span> discount!</h3>
        <p style="margin: 5px 0 10px 0; font-size: 14px;">Use this code at checkout to secure your workshop seat:</p>
        <div id="codeDisplay" class="code-display"></div>
        <small style="color: #666;">Take a screenshot of this code. Valid for 24 hours.</small>
    </div>
</div>

<script>
    const canvas = document.getElementById('wheelCanvas');
    const ctx = canvas.getContext('2d');
    const spinBtn = document.getElementById('spinBtn');
    const resultBox = document.getElementById('resultBox');
    const lockoutMsg = document.getElementById('lockoutMsg');

    // Define the slices precisely matching your requested breakdown
    const segments = [
        { label: '£5 Off', value: 5, color: '#9d4edd' },
        { label: '£10 Off', value: 10, color: '#7b2cbf' },
        { label: '£5 Off', value: 5, color: '#5a189a' },
        { label: '£20 Off', value: 20, color: '#3c096c' },
        { label: '£10 Off', value: 10, color: '#9d4edd' },
        { label: '£5 Off', value: 5, color: '#7b2cbf' },
        { label: '£30 Off', value: 30, color: '#240046' }, // Only one £30 spot
        { label: '£20 Off', value: 20, color: '#5a189a' }
    ];

    const totalSegments = segments.length;
    const arc = Math.PI / (totalSegments / 2);
    let currentRotation = 0;

    // Draw the static visual sections of the wheel
    function drawWheel() {
        const radius = canvas.width / 2;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let i = 0; i < totalSegments; i++) {
            const angle = i * arc;
            ctx.fillStyle = segments[i].color;
            
            ctx.beginPath();
            ctx.moveTo(radius, radius);
            ctx.arc(radius, radius, radius, angle, angle + arc, false);
            ctx.lineTo(radius, radius);
            ctx.fill();

            // Render Text Inside Segments
            ctx.save();
            ctx.fillStyle = "white";
            ctx.font = "bold 16px sans-serif";
            ctx.translate(radius, radius);
            ctx.rotate(angle + arc / 2);
            ctx.textAlign = "right";
            ctx.fillText(segments[i].label, radius - 20, 5);
            ctx.restore();
        }
    }

    // Helper: Generates thematic but cryptic crypto-secure styled strings
    function generateUnpredictableCode(discountVal) {
        const financeWords = ['COMPOUND', 'GROWTH', 'POTENTIAL', 'ASSET', 'PORTFOLIO', 'INTEREST', 'DIVIDEND'];
        const bristolWords = ['BRIS', 'CLIFTON', 'TEMPLE', 'HARBOUR', 'AVON'];
        
        const word1 = bristolWords[Math.floor(Math.random() * bristolWords.length)];
        const word2 = financeWords[Math.floor(Math.random() * financeWords.length)];
        
        // Un-guessable unique alphanumeric tag appended to the end
        const cryptoString = Math.random().toString(36).substring(2, 6).toUpperCase();
        
        return `${word1}-${word2}-${discountVal}${cryptoString}`;
    }

    function checkDailyLockout() {
        const lastSpinDate = localStorage.getItem('last_spin_date');
        const todayStr = new Date().toDateString(); // Matches simply on the literal calendar date calendar track

        if (lastSpinDate === todayStr) {
            spinBtn.disabled = true;
            spinBtn.style.display = 'none';
            
            // Calculate hours left until midnight to show a countdown standard
            const now = new Date();
            const midnight = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
            const hoursLeft = Math.ceil((midnight - now) / (1000 * 60 * 60));
            
            lockoutMsg.style.display = 'block';
            lockoutMsg.innerHTML = `⚠️ You've already used your daily spin! Come back in <strong>${hoursLeft} hours</strong> for your next attempt.`;
            return true;
        }
        return false;
    }

    function spinWheel() {
        if (checkDailyLockout()) return;

        spinBtn.disabled = true;
        resultBox.style.display = 'none';

        // Choose a random segment to land on dynamically
        const targetedSegmentIndex = Math.floor(Math.random() * totalSegments);
        
        // Calculate the rotation required to align the target with the 12 o'clock pointer
        const degreesPerSegment = 360 / totalSegments;
        const targetAngleDegrees = (targetedSegmentIndex * degreesPerSegment) + (degreesPerSegment / 2);
        const physicalCorrection = 270 - targetAngleDegrees; 
        
        // Add 5 full visual spins to hide the exact target destination mechanics
        const finalRotationDegrees = (360 * 5) + physicalCorrection;
        
        canvas.style.transform = `rotate(${finalRotationDegrees}deg)`;

        // Handle calculation logic safely in parallel tracking timelines
        setTimeout(() => {
            const prize = segments[targetedSegmentIndex];
            
            // Lock out the user right away for the day
            localStorage.setItem('last_spin_date', new Date().toDateString());

            // Render and display their unique code
            document.getElementById('rewardAmount').innerText = prize.label;
            document.getElementById('codeDisplay').innerText = generateUnpredictableCode(prize.value);
            resultBox.style.display = 'block';
            
            // Re-verify interface styling limits
            checkDailyLockout();
        }, 4000); // Transitions align with 4s CSS settings exactly
    }

    // Initialize layout immediately on view load
    drawWheel();
    checkDailyLockout();
</script>

</body>
</html>
